# 前端服务镜像：运行 Streamlit 页面
FROM python:3.11-slim

# 关闭 .pyc 写入并让日志实时输出，便于 docker logs 查看前端状态
ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1

# 容器内项目目录
WORKDIR /app

# 先复制依赖文件，利用 Docker 缓存减少重复安装时间
COPY requirements.txt /app/requirements.txt

# 安装 Python 依赖
RUN pip install --no-cache-dir --timeout 300 --retries 5 -i https://pypi.tuna.tsinghua.edu.cn/simple -r /app/requirements.txt

# 复制项目代码
COPY . /app

# 确保前端也能访问挂载后的 data 目录
RUN mkdir -p /app/data/chroma

# 暴露 Streamlit 前端端口
EXPOSE 8501

# 启动前端服务，关闭自动打开浏览器，并监听容器外部可访问地址
CMD ["streamlit", "run", "frontend/app.py", "--server.address=0.0.0.0", "--server.port=8501", "--server.headless=true"]
