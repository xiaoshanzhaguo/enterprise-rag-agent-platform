# 大模型服务配置
BASE_URL=your_llm_base_url
LLM_MODEL=your_llm_model

# Embedding 与向量检索配置
EMBEDDING_MODEL=your_embedding_model
VECTOR_STORE_DIR=./data/chroma
# 首次启动建议使用 keyword；安装 chromadb 并配置 embedding 后，再改成 vector。
RAG_RETRIEVAL_MODE=keyword

# 前后端服务配置
FRONTEND_BACKEND_BASE_URL=http://127.0.0.1:8000

# RAG 展示与存储配置
RAG_STORE_TTL_SECONDS=3600
RAG_STORE_MAX_SESSIONS=50
RAG_PREVIEW_TEXT_LIMIT=220

# SQLite 数据库配置
DATABASE_URL=sqlite:///./data/app.db
