# 大模型服务配置
BASE_URL=your_llm_base_url
DEEPSEEK_API_KEY=your_api_key
LLM_MODEL=your_llm_model

# Embedding 与向量检索配置
# 默认使用本地开源模型，便于演示和避免云端扣费风险。
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=BAAI/bge-m3
# 如果 EMBEDDING_PROVIDER=openai，则替换为云端 embedding 服务地址和 Key。
EMBEDDING_BASE_URL=your_embedding_base_url
EMBEDDING_API_KEY=your_embedding_api_key
VECTOR_STORE_DIR=./data/chroma
# RAG 检索模式。vector 表示向量检索，keyword 表示关键词检索。
RAG_RETRIEVAL_MODE=vector

# 前后端服务配置
FRONTEND_BACKEND_BASE_URL=http://127.0.0.1:8000

# RAG 展示与存储配置
RAG_STORE_TTL_SECONDS=3600
RAG_STORE_MAX_SESSIONS=50
RAG_PREVIEW_TEXT_LIMIT=120
# 向量检索最低相似度阈值，低于该分数时视为知识库没有可靠依据。
RAG_VECTOR_SCORE_THRESHOLD=0.6
# 向量检索没有可靠命中时，是否允许回退到关键词检索。
RAG_KEYWORD_FALLBACK_ENABLED=true

# SQLite 数据库配置
DATABASE_URL=sqlite:///./data/app.db
