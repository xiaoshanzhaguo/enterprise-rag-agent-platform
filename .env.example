# 大模型服务配置
BASE_URL=your_llm_base_url
DEEPSEEK_API_KEY=your_api_key
LLM_MODEL=your_llm_model

# Embedding 与向量检索配置
# 默认使用本地开源模型，便于演示和避免云端扣费风险。
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=BAAI/bge-m3
# 如果 EMBEDDING_PROVIDER=openai，则可以单独配置云端 embedding 服务；为空时复用大模型服务配置。
EMBEDDING_BASE_URL=
EMBEDDING_API_KEY=
VECTOR_STORE_DIR=./data/chroma
# 首次启动建议使用 keyword；安装 chromadb 并配置 embedding 后，再改成 vector。
RAG_RETRIEVAL_MODE=keyword

# 前后端服务配置
FRONTEND_BACKEND_BASE_URL=http://127.0.0.1:8000

# RAG 展示与存储配置
RAG_STORE_TTL_SECONDS=3600
RAG_STORE_MAX_SESSIONS=50
RAG_PREVIEW_TEXT_LIMIT=220
# 向量检索最低相似度阈值，低于该分数时视为知识库没有可靠依据。
RAG_VECTOR_SCORE_THRESHOLD=0.6

# SQLite 数据库配置
DATABASE_URL=sqlite:///./data/app.db
