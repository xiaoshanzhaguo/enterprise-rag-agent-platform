# 后端服务镜像：运行 FastAPI + RAG + SQLite 初始化逻辑
FROM python:3.11-slim

# 关闭 .pyc 写入并让日志实时输出，便于 docker logs 查看后端状态
ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1

# 容器内项目目录
WORKDIR /app

# 先复制依赖文件，利用 Docker 缓存减少重复安装时间
COPY requirements.txt /app/requirements.txt

# 安装 Python 依赖
RUN pip install --no-cache-dir --timeout 300 --retries 5 -i https://pypi.tuna.tsinghua.edu.cn/simple -r /app/requirements.txt

# 复制项目代码
COPY . /app

# 确保数据库和 ChromaDB 持久化目录存在
RUN mkdir -p /app/data/chroma

# 暴露 FastAPI 后端端口
EXPOSE 8000

# 启动后端服务，监听容器外部可访问地址
CMD ["uvicorn", "backend.main:app", "--host", "0.0.0.0", "--port", "8000"]
